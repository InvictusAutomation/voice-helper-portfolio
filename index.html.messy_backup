<div id="walker"><img src="design/assembled.gif" alt="Demo preview"></div>

<!-- ═══════════════ SCENE 1: OPENING ═══════════════ -->
<section class="scene scene-opening" data-scene="opening">
  <div>
    <p class="reveal" style="font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--teal-light);margin-bottom:20px">Voice First AI · Proactive &amp; Context-Aware</p>
    <h1 class="reveal" style="transition-delay:.15s">Voice Helper</h1>
    <p class="subtitle reveal" style="transition-delay:.3s">一个会成长的 AI 伙伴<br>从线性对话中提取结构化知识，拥有自己的「主体性」</p>
    <div class="sound-wave reveal" style="justify-content:center;transition-delay:.5s" id="hero-wave"></div>
  </div>
  <div class="scroll-indicator reveal" style="transition-delay:.8s">
    <span>Scroll to explore</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ═══════════════ SCENE 2: THE IDEA ═══════════════ -->
<section class="scene" data-scene="idea">
  <div class="chapter-card" data-chapter><div class="ch-num">Chapter 01</div><h2>The Idea</h2></div>
  <div class="scene-content">
    <h2 class="reveal-left">传统 AI 助手是「问一句答一句」<br>但真正的伙伴不是这样。</h2>
    <div class="section-divider reveal"></div>
    <p class="reveal" style="transition-delay:.2s">市面上的语音助手本质上都是「快速搜索引擎」——你问，它答。对话结束，上下文清零。它们没有记忆、没有主动性，更不理解你的世界。</p>
    <p class="reveal" style="transition-delay:.35s">Voice Helper 的出发点很简单：<strong>如果 AI 能像真正关心你的人一样——记住你说过的、理解你没说的、在你需要时主动出现——那会是怎样的体验？</strong></p>
    <div class="quote-float reveal-float">"最好的界面不是等待你操作的那个，而是预判你需求的那个。"</div>

    <!-- Key stats -->
    <div class="stats-row reveal" style="transition-delay:.45s">
      <div class="stat-item"><div class="stat-number">4</div><div class="stat-label">State Machine</div></div>
      <div class="stat-item"><div class="stat-number">&lt;1.5s</div><div class="stat-label">Voice Latency</div></div>
      <div class="stat-item"><div class="stat-number">2</div><div class="stat-label">Realtime Providers</div></div>
      <div class="stat-item"><div class="stat-number">∞</div><div class="stat-label">Memory Growth</div></div>
    </div>
  </div>
</section>

<!-- ═══════════════ SCENE 3: CORE PRINCIPLES ═══════════════ -->
<section class="scene" data-scene="principles">
  <div class="chapter-card" data-chapter><div class="ch-num">Chapter 02</div><h2>Core Principles</h2></div>
  <div class="scene-content">
    <h2 class="reveal-right">四大核心理念<br><span style="font-size:.55em;color:var(--text-dim)">定义了 Voice Helper 与传统助手的所有区别</span></h2>
    <div class="section-divider reveal"></div>
    <div class="framework-grid reveal" style="transition-delay:.15s">
      <div class="fw-card">
        <h4>主动性 Proactive</h4>
        <p>不只回答问题，还会主动关心、提醒、分享。基于学习到的模式和上下文信号，在用户需要之前就提供帮助。</p>
      </div>
      <div class="fw-card">
        <h4>记忆性 Memory</h4>
        <p>记住对话中的重要信息，通过 Mem0 向量化存储形成长期知识积累，支持语义检索和跨会话回忆。</p>
      </div>
      <div class="fw-card">
        <h4>成长性 Growth</h4>
        <p>从每次交互中学习，不断优化对用户的理解和回复质量。越用越懂你。</p>
      </div>
      <div class="fw-card">
        <h4>关系性 Relational</h4>
        <p>理解人际关系网络，记住用户重视的人事物，在合适的时机主动提及和关怀。</p>
      </div>
    </div>

    <!-- Code glimpse -->
    <p class="reveal" style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-dim);margin:40px 0 16px">Architecture Glimpse</p>
    <div class="code-block reveal" style="transition-delay:.3s">
<span class="c-cmt"># Hybrid scheme: OpenAI voice + DashScope brain</span>
<span class="c-kw">class</span> <span class="c-var">Brain</span>:
    <span class="c-cmt"># Background intelligence — never blocks hot path</span>
    <span class="c-kw">async def</span> <span class="c-fn">process_input</span>(<span class="c-var">self</span>, text):
        <span class="c-var">self</span>.memory.<span class="c-fn">add_conversation</span>(<span class="c-str">"user"</span>, text)
        memories = <span class="c-var">self</span>.memory.<span class="c-fn">search</span>(text, limit=<span class="c-str">5</span>)
        switch = <span class="c-kw">await</span> <span class="c-var">self</span>.sm.<span class="c-fn">_detect_state_switch</span>(text)
        <span class="c-cmt"># Fire-and-forget: never blocks audio pipeline</span>
    </div>
  </div>
</section>

<!-- ═══════════════ SCENE 4: TECH STACK DEEP DIVE ═══════════════ -->
<section class="scene" data-scene="tech">
  <div class="chapter-card" data-chapter><div class="ch-num">Chapter 03</div><h2>Tech Stack</h2></div>
  <div class="scene-content">
    <h2 class="reveal-left">双模型架构<br><span style="font-size:.55em;color:var(--text-dim)">OpenAI Realtime Voice + DashScope Qwen Intelligence Brain</span></h2>
    <div class="section-divider reveal"></div>
    <p class="reveal">Voice Helper 采用独特的双模型混合架构：语音交互层使用 OpenAI/DashScope Realtime API 实现超低延迟（&lt;1.5s），而智能决策层（状态机、记忆检索、意图判断）全部由阿里云 DashScope Qwen 驱动，兼顾速度与中文能力。</p>

    <div class="framework-grid reveal" style="transition-delay:.2s">
      <div class="fw-card">
        <h4>Realtime Voice Layer</h4>
        <p><strong>OpenAI gpt-4o-mini-realtime</strong> 或 <strong>DashScope qwen3.5-omni-plus-realtime</strong> · Server-side VAD · 打断机制 (Barge-in) · 长篇模式自动切换</p>
      </div>
      <div class="fw-card">
        <h4>Intelligence Engine</h4>
        <p>DashScope <strong>qwen-plus</strong> 对话 + <strong>qwen-turbo</strong> 判断决策 · 异步后台处理管线 · 不阻塞音频热路径</p>
      </div>
      <div class="fw-card">
        <h4>Memory System</h4>
        <p><strong>Mem0</strong> + Qdrant 向量存储 + <strong>text-embedding-v3</strong> · 结构化事实提取 · 跨会话语义检索</p>
      </div>
      <div class="fw-card">
        <h4>MCP Tool Extension</h4>
        <p>Model Context Protocol via FastMCP · Web 搜索工具 · SSE 工具服务器架构 · 可插拔扩展设计</p>
      </div>
      <div class="fw-card">
        <h4>State Machine</h4>
        <p>IDLE → ENGAGED → FADING → SILENT 四态模型 · LLM 驱动的状态转换检测 · 渐进式自主性调节</p>
      </div>
      <div class="fw-card">
        <h4>Voice Configuration</h4>
        <p><code>voice_config.yaml</code> 驱动 · 音色/VAD 参数/token 上限/打断关键词 全部可配置 · 热加载无需改代码</p>
      </div>
    </div>

    <div class="research-viz reveal-scale" id="research-viz-tech"></div>
  </div>
</section>

<!-- ═══════════════ SCENE 5: ARCHITECTURE ═══════════════ -->
<section class="scene scene-warm" data-scene="architecture">
  <div class="chapter-card" data-chapter><div class="ch-num">Chapter 04</div><h2>Architecture</h2></div>
  <div class="scene-content">
    <h2 class="reveal-right">三层解耦架构<br>热路径与冷路径分离</h2>
    <div class="section-divider reveal"></div>
    <p class="reveal">整个系统被清晰地分为三层：用户交互层（语音/文本）、核心引擎层（对话/记忆/推理）、外部服务层（LLM API/MCP 工具）。关键设计决策：**Brain 引擎的所有 LLM 调用都在异步后台执行，绝不阻塞音频热路径**。</p>

    <div class="arch-diagram reveal-scale">
      <div class="arch-layer arch-layer-ui">
        <div class="arch-label">Layer 1 · User Interface</div>
        <div class="arch-title">交互层</div>
        <div class="arch-modules">
          <span class="arch-module">Realtime WebSocket</span>
          <span class="arch-module">Text Terminal</span>
          <span class="arch-module">Server VAD</span>
          <span class="arch-module">Audio Stream</span>
        </div>
      </div>
      <div class="arch-arrow">▼</div>
      <div class="arch-layer arch-layer-engine">
        <div class="arch-label">Layer 2 · Core Engine</div>
        <div class="arch-title">核心引擎 (Async Background)</div>
        <div class="arch-modules">
          <span class="arch-module">🧠 Brain (process_input)</span>
          <span class="arch-module">💾 MemoryManager (Mem0+Qdrant)</span>
          <span class="arch-machine">⚡ StateMachine (4-state)</span>
          <span class="arch-module">🔔 Trigger (proactive)</span>
          <span class="arch-module">🔗 MCPBridge (tools)</span>
        </div>
      </div>
      <div class="arch-arrow">▼</div>
      <div class="arch-layer arch-layer-ext">
        <div class="arch-label">Layer 3 · External Services</div>
        <div class="arch-title">外部服务</div>
        <div class="arch-modules">
          <span class="arch-module">OpenAI Realtime API</span>
          <span class="arch-module">DashScope (Qwen + Embedding)</span>
          <span class="arch-module">MCP SSE Servers</span>
          <span class="arch-module">Qdrant Vector DB</span>
        </div>
      </div>
    </div>

    <div class="quote-float reveal-float">"热路径只做一件事：收音频 → 发音频。所有思考都在冷路径的 Brain 里异步完成。"</div>
  </div>
</section>

<!-- ═══════════════ SCENE 6: THE PRODUCT — INTERACTIVE DEMO ═══════════════ -->
<section class="scene scene-warm" data-scene="product">
  <div class="chapter-card" data-chapter><div class="ch-num">Chapter 05</div><h2>Try It</h2></div>
  <div class="scene-content">
    <h2 class="reveal-left">Voice Helper<br><span style="font-size:.65em;color:var(--text-dim);font-weight:300">可交互 Demo · 直接体验</span></h2>
    <div class="section-divider reveal"></div>
    <p class="reveal">下方是一个真实的交互式 Demo。你可以直接输入消息与 Voice Helper 对话。当前运行在<strong>模拟模式</strong>（无需后端即可体验），部署 Render 后端后将自动切换到真实 AI 对话模式。</p>

    <!-- Interactive Chat Widget -->
    <div id="voice-helper-demo" data-api-url="" class="reveal-scale"></div>

    <!-- Current capabilities -->
    <p class="reveal" style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-dim);margin:36px 0 16px">Phase 1 Capabilities</p>
    <div class="framework-grid reveal" style="transition-delay:.15s">
      <div class="fw-card">
        <h4>三种运行模式</h4>
        <p><code>--mode realtime</code> 超低延迟语音 (~1s) · <code>--mode fast</code> Agents SDK 低延迟 · <code>--mode agents</code> 全功能含 MCP 搜索</p>
      </div>
      <div class="fw-card">
        <h4>SILENT Mode</h4>
        <p>LLM 驱动的静默模式切换 · 在 SILENT 中仅倾听不回应 · 支持静默指令执行（设闹钟/记笔记）· Beep 确认反馈</p>
      </div>
      <div class="fw-card">
        <h4>Proactive Trigger</h4>
        <p>IDLE 状态下的定时扫描 · 基于记忆和上下文判断是否值得主动说话 · 智能退避算法避免打扰</p>
      </div>
      <div class="fw-card">
        <h4>Barge-in Interrupt</h4>
        <p>用户可在 AI 说话时插话中断 · 触发词列表可配置（"别讲了""停下""算了"等）· 中断后立即停止并等待新输入</p>
      </div>
      <div class="fw-card">
        <h4>Long Mode Detection</h4>
        <p>自动检测故事/分析请求 → 动态提升 token 上限至 300 · 口语化长输出 · 故事有头尾、分析有观点</p>
      </div>
      <div class="fw-card">
        <h4>Time Injection</h4>
        <p>识别时间相关提问 → 注入精确日期/星期/时间 → AI 能准确回答"现在几点""今天星期几"</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ SCENE 7: ROADMAP ═══════════════ -->
<section class="scene scene-warm" data-scene="roadmap">
  <div class="chapter-card" data-chapter><div class="ch-num">Chapter 06</div><h2>Roadmap</h2></div>
  <div class="scene-content">
    <h2 class="reveal-right">From Assistant<br>to Companion</h2>
    <div class="section-divider reveal"></div>

    <p class="reveal" style="font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--teal-light);margin-bottom:16px">Phase 1 ✅ — Now (Current State)</p>
    <div class="framework-grid reveal" style="transition-delay:.1s">
      <div class="fw-card" style="border-left:3px solid var(--teal)">
