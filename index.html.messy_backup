<script src="demo-widget.js"></script>
<script src="demo-widget.js"></script>
<script>
// ═══ SCROLL REVEAL ═══
const ro=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');ro.unobserve(e.target)}}),{threshold:.15});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el=>ro.observe(el));
const scenes=document.querySelectorAll('.scene');
scenes.forEach(s=>{const cc=s.querySelector('.chapter-card');if(!cc)return;
  const ro2=new IntersectionObserver(e=>{if(e[0].isIntersecting>.1)cc.classList.add('slide-in')},{threshold:.1});
  ro2.observe(s);
});
// ═══ TIMELINE DOTS + PROGRESS ═══
const dotsC=document.getElementById('timeline-dots'),prog=document.getElementById('timeline-progress'),dots=[];
scenes.forEach(s=>{const d=document.createElement('div');d.className='tl-dot';d.style.top=(s.offsetTop+s.offsetHeight/2)+'px';d._warm=s.classList.contains('scene-warm');dotsC.appendChild(d);dots.push(d)});
var ambient=document.getElementById('ambient-bg');
var navy={r:10,g:22,b:40},tealC={r:13,g:148,b:136},amberC={r:245,g:158,b:11};
function lerp(a,b,t){return a+(b-a)*t}
function lerpC(c1,c2,t){return 'rgb('+Math.round(lerp(c1.r,c2.r,t))+','+Math.round(lerp(c1.g,c2.g,t))+','+Math.round(lerp(c1.b,c2.t))+')'}
var ticking=false;
window.addEventListener('scroll',function(){if(ticking)return;ticking=true;requestAnimationFrame(function(){
  var sy=window.scrollY,ms=document.documentElement.scrollHeight-window.innerHeight,p=Math.min(sy/Math.max(ms,1),1);
  prog.style.height=(p*100)+'%';
  var col;if(p<.5)col=lerpC(navy,tealC,p*2);else col=lerpC(tealC,amberC,(p-.5)*2);
  ambient.style.background='radial-gradient(ellipse 120% 80% at 50% 50%,'+col+',#0A1628)';
  ticking=false})},{passive:true});
(function(){
  var dotObs=new IntersectionObserver(function(entries){
    entries.forEach(function(en){
      var idx=Array.prototype.indexOf.call(scenes,en.target);
      if(idx<0||!dots[idx])return;
      if(en.isIntersecting){dots[idx].classList.add('active');if(dots[idx]._warm)dots[idx].classList.add('warm')}
      else{dots[idx].classList.remove('active','warm')}
    });
  },{threshold:.25,rootMargin:'-10% 0px -10% 0px'});
  scenes.forEach(function(s){dotObs.observe(s)});
})();
dots.forEach(function(d,i){d.addEventListener('click',function(){var t=scenes[i];if(t){var o=t.getBoundingClientRect().top+window.scrollY-80;window.scrollTo({top:o,behavior:'smooth'})}})});
document.addEventListener('mousemove',function(e){ambient.style.setProperty('--mx',(e.clientX/window.innerWidth*100)+'%');ambient.style.setProperty('--my',(e.clientY/window.innerHeight*100)+'%')});
// ═══ NAV ACTIVE STATE + SMOOTH SCROLL OFFSET ═══
const navLinks=document.querySelectorAll('.nav-links a');
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',function(e){
    e.preventDefault();
    const t=document.querySelector(this.getAttribute('href'));
    if(t){const o=t.getBoundingClientRect().top+window.scrollY-80;window.scrollTo({top:o,behavior:'smooth'})}
  });
});
const navObs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){const t=e.target.id;navLinks.forEach(a=>{a.classList.toggle('active',a.dataset.target===t)})}})},{threshold:.3});
document.querySelectorAll('.scene[id]').forEach(el=>navObs.observe(el));
// ═══ WALKING CHARACTER (GIF) ═══
(function(){
  var w=document.getElementById('walker');if(!w)return;
  var ww=window.innerWidth,wh=window.innerHeight,x=-420,speed=.8,direction=1,currentScale=1,baseY=wh*.55+window.scrollY,enterFromLeft=true;
  window.addEventListener('resize',function(){ww=window.innerWidth;wh=window.innerHeight});
  w.style.opacity='1';function step(){
    var sy=window.scrollY;x+=speed*direction;var imgWidth=w.offsetWidth||320;
    if(x>ww+40){enterFromLeft=false;x=-(imgWidth+40);direction=1}
    else if(x<-(imgWidth+40)){enterFromLeft=true;x=ww+40;direction=-1}
    var screenY=baseY-sy;var margin=wh*.3;
    if(screenY<-margin||screenY>wh+margin){baseY=sy+wh*(.35+Math.random()*.35);currentScale=Math.random()<.1?2:(.8+Math.random()*.4);if(enterFromLeft){x=-(imgWidth+40);direction=1;enterFromLeft=false}else{x=ww+40;direction=-1;enterFromLeft=true}screenY=baseY-sy}
    w.style.left=x+'px';w.style.top=screenY+'px';w.style.bottom='auto';w.style.transform='scale('+direction*currentScale+','+currentScale+')';requestAnimationFrame(step);
  }requestAnimationFrame(step);
})();
// ═══ NODE SIDEBAR INTERACTIONS ═══
function showNodePreview(el){document.querySelectorAll('.node-item').forEach(n=>n!==el&&n.classList.remove('active'));el.classList.add('active');const pv=el.querySelector('.node-preview');if(pv)pv.classList.add('visible');}
function hideNodePreview(el){const pv=el.querySelector('.node-preview');if(pv)pv.classList.remove('visible');}
document.querySelectorAll('.node-item').forEach(n=>{n.addEventListener('click',function(){document.querySelectorAll('.node-item').forEach(x=>x!==this&&x.classList.remove('active'));this.classList.toggle('active');const pv=this.querySelector('.node-preview');if(pv)pv.classList.toggle('visible',this.classList.contains('active'))});});
// ═══ DOWNLOAD COUNTER + MODAL ═══
(function(){let dl=parseInt(localStorage.getItem('rc_resume_dl')||'0');document.getElementById('download-count').textContent=dl})();
function openDownloadModal(){document.getElementById('dl-modal').classList.add('active');document.getElementById('form-area').style.display='block';document.getElementById('success-area').style.display='none'}
function closeDownloadModal(){document.getElementById('dl-modal').classList.remove('active')}
function submitDownload(){const ei=document.getElementById('dl-email');ei.classList.remove('error');const em=ei.value.trim();if(!em||!em.includes('@')){ei.classList.add('error');return}let ct=parseInt(localStorage.getItem('rc_resume_dl')||'0')+1;localStorage.setItem('rc_resume_dl',ct);document.getElementById('download-count').textContent=ct;document.getElementById('form-area').style.display='none';document.getElementById('success-area').style.display='block';const a=document.createElement('a');a.href='resume.pdf';a.download='陈厚瑄_简历_RockChen_2026.04.pdf';document.body.appendChild(a);a.click();document.body.removeChild(a);setTimeout(closeDownloadModal,2000)}
document.getElementById('dl-modal').addEventListener('click',function(e){if(e.target===this)closeDownloadModal()});
</script>
