<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rock Chen 陈厚瑄 — AI × 产品 × 工程</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0A1628;--navy-mid:#0F2847;
  --teal:#0D9488;--teal-light:#14B8A6;
  --amber:#F59E0B;--amber-light:#FBBF24;
  --text-light:rgba(255,255,255,.88);
  --text-dim:rgba(255,255,255,.55);
  --fh:'Space Grotesk',sans-serif;
  --fb:'Space Grotesk',system-ui,sans-serif;
  --fm:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:var(--fb);color:var(--text-light);background:var(--navy);overflow-x:hidden;line-height:1.7;-webkit-font-smoothing:antialiased}

/* ── AMBIENT BG ── */
#ambient-bg{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse 120% 80% at 50% 50%,var(--navy-mid),var(--navy));transition:background 1.2s ease}
#ambient-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(circle 500px at var(--mx,50%) var(--my,40%),rgba(13,148,136,.22) 0%,rgba(13,148,136,.10) 30%,transparent 65%);transition:background .6s ease}
#ambient-bg{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse 120% 80% at 50% 50%,var(--navy-mid),var(--navy));transition:background 1.2s ease}
#ambient-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(circle 500px at var(--mx,50%) var(--my,40%),rgba(13,148,136,.22) 0%,rgba(13,148,136,.10) 30%,transparent 65%);transition:background .6s ease}
/* ── TIMELINE ── */
#timeline{position:fixed;left:52px;top:0;height:100vh;width:2px;z-index:100;background:rgba(255,255,255,.06)}
#timeline-progress{width:100%;background:linear-gradient(180deg,var(--teal),var(--amber));border-radius:0 0 2px 2px;transition:height .15s ease;box-shadow:0 0 12px rgba(13,148,136,.5)}
#timeline-dots{position:fixed;left:52px;top:0;height:100vh;z-index:101;pointer-events:none}
.tl-dot{position:absolute;width:22px;height:22px;border-radius:50%;border:2.5px solid rgba(255,255,255,.18);background:var(--navy);transition:all .5s cubic-bezier(.23,1,.32,1);transform:translate(-50%,-50%);cursor:pointer;pointer-events:auto}
.tl-dot.active{border-color:var(--teal-light);background:var(--teal);box-shadow:0 0 22px rgba(13,148,136,.6),0 0 6px rgba(13,148,136,.8);transform:translate(-50%,-50%) scale(1.15)}
.tl-dot.warm{border-color:var(--amber-light);background:var(--amber);box-shadow:0 0 22px rgba(245,158,11,.5),0 0 6px rgba(245,158,11,.7)}
.scene{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;z-index:1;overflow:hidden;padding:80px 60px 80px 100px}
.reveal{opacity:0;transform:translateY(60px);transition:opacity .9s cubic-bezier(.23,1,.32,1),transform .9s cubic-bezier(.23,1,.32,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-80px);transition:opacity .9s cubic-bezier(.23,1,.32,1),transform .9s cubic-bezier(.23,1,.32,1)}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(80px);transition:opacity .9s cubic-bezier(.23,1,.32,1),transform .9s cubic-bezier(.23,1,.32,1)}
.reveal-right.visible{opacity:1;transform:translateX(0)}
.reveal-scale{opacity:0;transform:scale(.85);transition:opacity .8s ease,transform .8s cubic-bezier(.23,1,.32,1)}
.reveal-scale.visible{opacity:1;transform:scale(1)}
.reveal-float{opacity:0;transform:translateY(100px);transition:1s ease .2s,transform 1s cubic-bezier(.23,1,.32,1) .2s}
.reveal-float.visible{opacity:1;transform:translateY(0)}
.chapter-card{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;align-items:flex-end;padding:40px 50px;opacity:0;
  pointer-events:none;z-index:0;
  transition:opacity .6s ease}
.chapter-card .ch-num{font-family:var(--fm);font-size:.72rem;text-transform:uppercase;letter-spacing:.4em;color:var(--teal-light);opacity:0;margin-bottom:8px;
  transition:opacity .8s ease .3s,transform 1s cubic-bezier(.23,1,.32,1);
  transform:translateY(20px)}
.chapter-card h2{font-family:var(--fh);font-size:clamp(3rem,7vw,5.5rem);font-weight:300;letter-spacing:-.02em;line-height:1;
  color:rgba(13,148,136,.10);opacity:0;
  transition:opacity .8s ease .4s,transform 1s cubic-bezier(.23,1,.32,1);
  transform:translateY(30px)}
.chapter-card.slide-in{opacity:1}
.chapter-card.slide-in .ch-num,.chapter-card.slide-in h2{opacity:1;transform:translateY(0)}
.scene-warm .chapter-card .ch-num{color:var(--amber-light)}
.scene-warm .chapter-card h2{color:rgba(245,158,11,.10)}
.quote-float{position:relative;padding:32px 40px;margin:48px 0;border-left:2px solid var(--teal-light);background:linear-gradient(135deg,rgba(13,148,136,.06),transparent);font-family:var(--fh);font-size:1.35rem;font-style:italic;line-height:1.8;color:rgba(255,255,255,.82);max-width:680px}
.quote-float::before{content:'\201C';position:absolute;top:-10px;left:16px;font-size:4rem;color:var(--teal-light);opacity:.4;font-style:normal}
.sound-wave{display:flex;align-items:center;gap:3px;height:60px}
.sound-wave span{width:4px;border-radius:4px;background:var(--teal-light);animation:wave 1.2s ease-in-out infinite}
@keyframes wave{0%,100%{height:8px;opacity:.3}50%{height:var(--h,40px);opacity:1}}
.btn-outline{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border:1px solid rgba(255,255,255,.25);border-radius:40px;color:var(--text-light);text-decoration:none;font-family:var(--fb);font-size:.85rem;letter-spacing:.06em;text-transform:uppercase;transition:all .4s ease;cursor:pointer;background:transparent}
.btn-outline:hover{border-color:var(--teal-light);background:rgba(13,148,136,.1);transform:translateY(-2px)}
.btn-warm{border-color:var(--amber);color:var(--amber-light)}
.btn-warm:hover{background:rgba(245,158,11,.1);border-color:var(--amber-light)}
.scroll-indicator{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:.5;animation:sp 2.5s ease-in-out infinite}
.scroll-indicator span{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-dim)}
.scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,var(--teal-light),transparent);animation:sl 2s ease-in-out infinite}
@keyframes sp{0%,100%{opacity:.3;transform:translateX(-50%) translateY(0)}50%{opacity:.7;transform:translateX(-50%) translateY(8px)}}
@keyframes sl{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}
.scene-opening{flex-direction:column;text-align:center}
.scene-opening h1{font-family:var(--fh);font-size:clamp(2.8rem,6vw,5rem);font-weight:300;line-height:1.15;margin-bottom:16px}
.scene-opening .subtitle{font-size:1.05rem;color:var(--text-dim);max-width:520px;margin:0 auto 40px}
.scene-content{max-width:860px}
.scene-content h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3.2rem);font-weight:300;line-height:1.25;margin-bottom:24px}
.scene-content p{font-size:1rem;line-height:1.9;color:rgba(255,255,255,.75);margin-bottom:20px;max-width:640px}
.section-divider{width:60px;height:1px;background:linear-gradient(90deg,var(--teal-light),transparent);margin:48px 0}
.framework-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin:40px 0}
.fw-card{padding:28px;border:1px solid rgba(255,255,255,.08);border-radius:12px;background:rgba(255,255,255,.02);transition:all .5s ease}
.fw-card:hover{border-color:var(--teal);background:rgba(13,148,136,.05);transform:translateY(-4px)}
.fw-card h4{font-family:var(--fh);font-size:1.25rem;margin-bottom:8px;color:var(--text-light)}
.fw-card p{font-size:.85rem;color:var(--text-dim);line-height:1.7}
.vision-tag{display:inline-block;padding:6px 16px;border:1px solid rgba(245,158,11,.3);border-radius:20px;font-size:.75rem;letter-spacing:.1em;color:var(--amber-light);margin:4px}
.scene-epilogue{text-align:center;flex-direction:column}
.epilogue-links{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.scene-warm{background:linear-gradient(180deg,transparent,rgba(245,158,11,.03) 50%,rgba(245,158,11,.06))}
.scene-warm .quote-float{border-left-color:var(--amber)}
.scene-warm .quote-float::before{color:var(--amber)}
.scene-warm .sound-wave span{background:var(--amber-light)}
.scene-warm .section-divider{background:linear-gradient(90deg,var(--amber),transparent)}

/* Architecture diagram */
.arch-diagram{width:100%;max-width:700px;margin:36px 0;padding:28px;border:1px solid rgba(13,148,136,.25);border-radius:14px;background:rgba(0,0,0,.35);position:relative;overflow:hidden}
.arch-diagram::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 30%,rgba(13,148,136,.04),transparent 70%)}
.arch-layer{text-align:center;padding:18px 22px;margin:10px 0;border-radius:10px;position:relative;z-index:1}
.arch-layer-ui{background:linear-gradient(135deg,rgba(13,148,136,.22),rgba(13,148,106,.12));border:1px solid rgba(13,148,136,.35)}
.arch-layer-engine{background:linear-gradient(135deg,rgba(245,158,11,.18),rgba(245,158,11,.08));border:1px solid rgba(245,158,11,.3)}
.arch-layer-ext{background:rgba(255,255,255,.05);border:1px dashed rgba(255,255,255,.2)}
.arch-label{font-family:var(--fb);font-size:.72rem;text-transform:uppercase;letter-spacing:.18em;color:var(--text-dim);margin-bottom:8px}
.arch-title{font-family:var(--fh);font-size:1.15rem;font-weight:400;color:var(--text-light)}
.arch-modules{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:8px}
.arch-module{font-size:.72rem;padding:3px 10px;border-radius:12px;background:rgba(255,255,255,.06);color:rgba(255,255,255,.7);white-space:nowrap}
.arch-arrow{display:flex;justify-content:center;padding:4px 0;color:var(--text-dim);font-size:1.2rem}

/* Code block */
.code-block{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:20px 24px;margin:28px 0;overflow-x:auto;font-family:'SF Mono',Menlo,monospace;font-size:.78rem;line-height:1.7;color:#a5f3fc}
.code-block .c-cmt{color:rgba(255,255,255,.35);font-style:italic}
.code-block .c-kw{color:#fbbf24}
.code-block .c-str{color:#34d399}
.code-block .c-fn{color:#93c5fd}
.code-block .c-var{color:#f9a8d4}

/* Stats row */
.stats-row{display:flex;gap:32px;margin:32px 0;flex-wrap:wrap}
.stat-item{text-align:center;flex:1;min-width:100px}
.stat-number{font-family:var(--fh);font-size:2.4rem;font-weight:300;color:var(--teal-light)}
.stat-label{font-size:.7rem;color:var(--text-dim);letter-spacing:.1em;text-transform:uppercase;margin-top:2px}


/* ═══════════════ EPILOGUE ═══════════════ */
.scene-epilogue{text-align:center;flex-direction:column}
.epilogue-links{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* ═══════════════ NAV ═══════════════ */
#scene-nav{position:fixed;top:24px;left:72px;z-index:200;display:flex;align-items:center;gap:20px;padding:8px 16px;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(10,22,40,.7);backdrop-filter:blur(12px);transition:opacity .4s ease,transform .4s ease}
.nav-brand{font-family:var(--fh);font-size:.85rem;font-weight:600;color:var(--teal-light);letter-spacing:.08em}
.nav-links{display:flex;gap:2px;list-style:none;margin:0;padding:0}
.nav-links li a{display:flex;align-items:center;gap:5px;padding:6px 10px;text-decoration:none;font-family:var(--fm);font-size:.65rem;letter-spacing:.08em;color:var(--text-dim);border-radius:6px;transition:all .25s ease;white-space:nowrap}
.nav-links li a:hover{color:var(--text-light);background:rgba(13,148,136,.1)}
.nav-links li a.active{color:var(--teal-light);background:rgba(13,148,136,.12)}
.nav-num{font-size:.55rem;opacity:.45;font-family:var(--fb)}

/* ═══════════════ WALKER (GIF) ═══════════════ */
#walker{position:fixed;z-index:5;pointer-events:none;width:320px;height:560px;top:55%;filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));will-change:transform,left,top}
#walker img{width:100%;height:100%;object-fit:contain;object-position:center bottom}

/* ═══════════════ GRAIN ═══════════════ */
#grain{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px}

/* Code block */
.code-block{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:20px 24px;margin:20px 0;overflow-x:auto;font-family:'SF Mono',Menlo,monospace;font-size:.78rem;line-height:1.7;color:#a5f3fc}

@media(max-width:768px){
  .scene{padding:60px 24px}
  #timeline,#timeline-dots{display:none}
  .chapter-card{position:relative;padding:20px 24px;align-items:flex-start;justify-content:flex-start}
  .chapter-card h2{font-size:2.5rem}
  .chapter-card.slide-in .ch-num,.chapter-card.slide-in h2{transform:translateY(0)}
  .scene-content h2{font-size:1.8rem}
  .sound-wave{justify-content:center}
  .framework-grid{grid-template-columns:1fr}
  .epilogue-links{flex-direction:column;align-items:center}
  .arch-diagram{padding:16px}
  .arch-modules{flex-direction:column;align-items:center}
  .stats-row{flex-direction:row;justify-content:center}
}
#grain{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px}

/* Scene navigation (top-left fixed) */
#scene-nav{position:fixed;top:24px;left:72px;z-index:200;display:flex;align-items:center;gap:20px;
  padding:8px 16px;border:1px solid rgba(255,255,255,.08);border-radius:10px;
  background:rgba(10,22,40,.7);backdrop-filter:blur(12px);
  transition:opacity .4s ease,transform .4s ease}
#scene-nav:hover{border-color:rgba(255,255,255,.14)}
.nav-brand{font-family:var(--fh);font-size:.85rem;font-weight:600;color:var(--teal-light);letter-spacing:.08em}
.nav-links{display:flex;gap:2px;list-style:none;margin:0;padding:0}
.nav-links li a{display:flex;align-items:center;gap:5px;padding:6px 10px;text-decoration:none;
  font-family:var(--fm);font-size:.65rem;letter-spacing:.08em;color:var(--text-dim);
  border-radius:6px;transition:all .25s ease;white-space:nowrap}
.nav-links li a:hover{color:var(--text-light);background:rgba(13,148,136,.1)}
.nav-links li a.active{color:var(--teal-light);background:rgba(13,148,136,.12)}
.nav-num{font-size:.55rem;opacity:.45;font-family:var(--fb)}
.nav-links li a.active .nav-num{opacity:1}


/* ═══════════════ EPILOGUE ═══════════════ */
.scene-epilogue{text-align:center;flex-direction:column}
.epilogue-links{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* ═══════════════ NAV ═══════════════ */
#scene-nav{position:fixed;top:24px;left:72px;z-index:200;display:flex;align-items:center;gap:20px;padding:8px 16px;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(10,22,40,.7);backdrop-filter:blur(12px);transition:opacity .4s ease,transform .4s ease}
.nav-brand{font-family:var(--fh);font-size:.85rem;font-weight:600;color:var(--teal-light);letter-spacing:.08em}
.nav-links{display:flex;gap:2px;list-style:none;margin:0;padding:0}
.nav-links li a{display:flex;align-items:center;gap:5px;padding:6px 10px;text-decoration:none;font-family:var(--fm);font-size:.65rem;letter-spacing:.08em;color:var(--text-dim);border-radius:6px;transition:all .25s ease;white-space:nowrap}
.nav-links li a:hover{color:var(--text-light);background:rgba(13,148,136,.1)}
.nav-links li a.active{color:var(--teal-light);background:rgba(13,148,136,.12)}
.nav-num{font-size:.55rem;opacity:.45;font-family:var(--fb)}

/* ═══════════════ WALKER (GIF) ═══════════════ */
#walker{position:fixed;z-index:5;pointer-events:none;width:320px;height:560px;top:55%;filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));will-change:transform,left,top}
#walker img{width:100%;height:100%;object-fit:contain;object-position:center bottom}

/* ═══════════════ GRAIN ═══════════════ */
#grain{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px}

/* Code block */
.code-block{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:20px 24px;margin:20px 0;overflow-x:auto;font-family:'SF Mono',Menlo,monospace;font-size:.78rem;line-height:1.7;color:#a5f3fc}

@media(max-width:900px){
  #scene-nav{left:12px;top:12px;padding:6px 10px;flex-direction:column;align-items:flex-start;gap:4px;max-width:160px}
  .nav-brand{display:none}
  .nav-links{flex-direction:column;gap:1px}
  .nav-links li a{padding:5px 8px;font-size:.62rem}
}

/* ═══════════════ EPILOGUE ═══════════════ */
.scene-epilogue{text-align:center;flex-direction:column}
.epilogue-links{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* ═══════════════ NAV ═══════════════ */
#scene-nav{position:fixed;top:24px;left:72px;z-index:200;display:flex;align-items:center;gap:20px;padding:8px 16px;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(10,22,40,.7);backdrop-filter:blur(12px);transition:opacity .4s ease,transform .4s ease}
.nav-brand{font-family:var(--fh);font-size:.85rem;font-weight:600;color:var(--teal-light);letter-spacing:.08em}
.nav-links{display:flex;gap:2px;list-style:none;margin:0;padding:0}
.nav-links li a{display:flex;align-items:center;gap:5px;padding:6px 10px;text-decoration:none;font-family:var(--fm);font-size:.65rem;letter-spacing:.08em;color:var(--text-dim);border-radius:6px;transition:all .25s ease;white-space:nowrap}
.nav-links li a:hover{color:var(--text-light);background:rgba(13,148,136,.1)}
.nav-links li a.active{color:var(--teal-light);background:rgba(13,148,136,.12)}
.nav-num{font-size:.55rem;opacity:.45;font-family:var(--fb)}

/* ═══════════════ WALKER (GIF) ═══════════════ */
#walker{position:fixed;z-index:5;pointer-events:none;width:320px;height:560px;top:55%;filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));will-change:transform,left,top}
#walker img{width:100%;height:100%;object-fit:contain;object-position:center bottom}

/* ═══════════════ GRAIN ═══════════════ */
#grain{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px}

/* Code block */
.code-block{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:20px 24px;margin:20px 0;overflow-x:auto;font-family:'SF Mono',Menlo,monospace;font-size:.78rem;line-height:1.7;color:#a5f3fc}

@media(max-width:768px){#scene-nav{display:none}}

/* Walking character — auto horizontal walk */
#walker{position:fixed;z-index:5;pointer-events:none;
  width:320px;height:560px;top:55%;
  filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));
  will-change:transform,left,top}
#walker img{width:100%;height:100%;object-fit:contain;object-position:center bottom}

/* ═══════════════ EPILOGUE ═══════════════ */
.scene-epilogue{text-align:center;flex-direction:column}
.epilogue-links{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* ═══════════════ NAV ═══════════════ */
#scene-nav{position:fixed;top:24px;left:72px;z-index:200;display:flex;align-items:center;gap:20px;padding:8px 16px;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(10,22,40,.7);backdrop-filter:blur(12px);transition:opacity .4s ease,transform .4s ease}
.nav-brand{font-family:var(--fh);font-size:.85rem;font-weight:600;color:var(--teal-light);letter-spacing:.08em}
.nav-links{display:flex;gap:2px;list-style:none;margin:0;padding:0}
.nav-links li a{display:flex;align-items:center;gap:5px;padding:6px 10px;text-decoration:none;font-family:var(--fm);font-size:.65rem;letter-spacing:.08em;color:var(--text-dim);border-radius:6px;transition:all .25s ease;white-space:nowrap}
.nav-links li a:hover{color:var(--text-light);background:rgba(13,148,136,.1)}
.nav-links li a.active{color:var(--teal-light);background:rgba(13,148,136,.12)}
.nav-num{font-size:.55rem;opacity:.45;font-family:var(--fb)}

/* ═══════════════ WALKER (GIF) ═══════════════ */
#walker{position:fixed;z-index:5;pointer-events:none;width:320px;height:560px;top:55%;filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));will-change:transform,left,top}
#walker img{width:100%;height:100%;object-fit:contain;object-position:center bottom}

/* ═══════════════ GRAIN ═══════════════ */
#grain{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px}

/* Code block */
.code-block{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:20px 24px;margin:20px 0;overflow-x:auto;font-family:'SF Mono',Menlo,monospace;font-size:.78rem;line-height:1.7;color:#a5f3fc}

@media(max-width:768px){#walker{width:200px;height:350px}}

/* Demo widget area */
