/* ═══════════════ WALKER (GIF) ═══════════════ */
#walker{position:fixed;z-index:5;pointer-events:none;width:320px;height:560px;top:55%;filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));will-change:transform,left,top}
#walker img{width:100%;height:100%;object-fit:contain;object-position:center bottom}

/* ═══════════════ GRAIN ═══════════════ */
#grain{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:256px}

/* Code block */
.code-block{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:20px 24px;margin:20px 0;overflow-x:auto;font-family:'SF Mono',Menlo,monospace;font-size:.78rem;line-height:1.7;color:#a5f3fc}

@media(max-width:768px){.about-grid{grid-template-columns:1fr}}
.about-intro p{font-size:.92rem;line-height:1.85;color:rgba(255,255,255,.72);margin-bottom:16px}
.skill-tags{display:flex;flex-wrap:wrap;gap:8px;margin:20px 0}
